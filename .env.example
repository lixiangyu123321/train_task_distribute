# ============================================================
# AI 训练与微调分布式任务调度系统 — 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# === CPU 调度节点公网地址 ===
SCHEDULER_PUBLIC_IP=<填入CPU节点公网IP>
SCHEDULER_API_PORT=8080
SCHEDULER_WS_PORT=8081

# === GPU Worker 节点 1 公网地址 ===
GPU1_PUBLIC_IP=<填入GPU节点1公网IP>
GPU1_API_PORT=9000
GPU1_NAME=gpu-worker-01

# === GPU Worker 节点 2 公网地址 ===
GPU2_PUBLIC_IP=<填入GPU节点2公网IP>
GPU2_API_PORT=9000
GPU2_NAME=gpu-worker-02

# === MySQL ===
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=ai_scheduler
MYSQL_USER=aisched
MYSQL_PASSWORD=<填入MySQL密码>
MYSQL_ROOT_PASSWORD=<填入MySQL root密码>

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<填入Redis密码>

# === 日志级别 ===
LOGGING_LEVEL=INFO
